// TikTok Worker - COMPLETELY NEW WORKING METHOD
export default {
  async fetch(request) {
    const url = new URL(request.url);
    
    if (url.pathname !== '/tik/dl') {
      return new Response('✅ TikTok API Worker is running', { status: 200 });
    }
    
    const tiktokUrl = url.searchParams.get('url');
    
    if (!tiktokUrl) {
      return new Response(JSON.stringify({ 
        success: false, 
        error: "Missing url parameter" 
      }), {
        headers: { 'Content-Type': 'application/json' }
      });
    }
    
    try {
      // ========== METHOD 1: Use tiktokdl.app (Most reliable) ==========
      let videoUrl = null;
      let author = "TikTok User";
      let caption = "";
      let likes = "0";
      let views = "0";
      let comments = "0";
      let shares = "0";
      let duration = "0:00";
      
      // Step 1: Get the actual video URL from tiktokdl.app
      const apiUrl = `https://tiktokdl.app/api/tiktokdl?url=${encodeURIComponent(tiktokUrl)}`;
      const response = await fetch(apiUrl, {
        headers: {
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
          'Accept': 'application/json',
          'Referer': 'https://tiktokdl.app/'
        }
      });
      
      if (response.ok) {
        const data = await response.json();
        console.log('TikTokDL data:', JSON.stringify(data));
        
        if (data.success && data.video) {
          videoUrl = data.video;
          author = data.author || "TikTok User";
          caption = data.title || "";
          likes = data.likes || "0";
          comments = data.comments || "0";
          shares = data.shares || "0";
          views = data.views || "0";
          duration = data.duration || "0:00";
        }
      }
      
      // ========== METHOD 2: Fallback to tiktokdl.com ==========
      if (!videoUrl) {
        const formData = new URLSearchParams();
        formData.append('url', tiktokUrl);
        formData.append('submit', 'Download');
        
        const fallbackRes = await fetch('https://tiktokdl.com/wp-json/tiktok-downloader/download', {
          method: 'POST',
          headers: {
            'User-Agent': 'Mozilla/5.0',
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: formData
        });
        
        if (fallbackRes.ok) {
          const fallbackData = await fallbackRes.json();
          if (fallbackData.video) {
            videoUrl = fallbackData.video;
            author = fallbackData.author || author;
            caption = fallbackData.caption || caption;
          }
        }
      }
      
      // ========== METHOD 3: Direct TikTok oEmbed (for stats only) ==========
      if (views === "0" || likes === "0") {
        try {
          // Extract video ID from URL
          let videoId = null;
          const idMatch = tiktokUrl.match(/video\/(\d+)/);
          if (idMatch) videoId = idMatch[1];
          
          if (videoId) {
            const embedRes = await fetch(`https://www.tiktok.com/oembed?url=https://www.tiktok.com/@user/video/${videoId}`);
            if (embedRes.ok) {
              const embedData = await embedRes.json();
              if (author === "TikTok User") author = embedData.author_name || author;
              if (caption === "") caption = embedData.title || caption;
            }
          }
        } catch(e) { console.log('oEmbed error:', e); }
      }
      
      if (!videoUrl) {
        throw new Error("Could not get video URL");
      }
      
      // Format numbers
      function formatStat(value) {
        if (!value || value === "0") return "Not available";
        return value.toString();
      }
      
      return new Response(JSON.stringify({
        success: true,
        video_url: videoUrl,
        author: author,
        caption: caption,
        stats: {
          views: formatStat(views),
          likes: formatStat(likes),
          comments: formatStat(comments),
          shares: formatStat(shares)
        },
        duration: duration,
        links: [{ url: videoUrl, filename: `${author.replace(/[^a-zA-Z0-9]/g, '_')}_tiktok.mp4` }]
      }), {
        headers: { 'Content-Type': 'application/json' }
      });
      
    } catch (error) {
      console.error('Worker error:', error);
      return new Response(JSON.stringify({
        success: false,
        error: error.message
      }), {
        headers: { 'Content-Type': 'application/json' }
      });
    }
  }
};
